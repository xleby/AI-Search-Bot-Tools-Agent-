# Токен бота от @BotFather
BOT_TOKEN=your_bot_token_here

# HTTP прокси для доступа к Telegram API (Cloudflare Workers reverse proxy)
# См. инструкцию по настройке в README.md
HTTP_PROXY=https://your-proxy.workers.dev

# SearXNG локальный сервер
SEARXNG_URL=http://127.0.0.1:8888

# Qwen LLM сервер (OpenAI-compatible API с tools)
MODEL_URL=http://127.0.0.1:8080

# Максимум результатов поиска
MAX_SEARCH_RESULTS=5

# Максимум статей для парсинга
MAX_ARTICLES_TO_PARSE=5

# Лимит символов материалов для LLM
MATERIALS_CHAR_LIMIT=90000
